# Environment variables example
# Copy this file to .env and fill in your values

# React App Port (default: 3000)
PORT=3000

# Enable/Disable Features
REACT_APP_ENABLE_INDEXEDDB=true
REACT_APP_ENABLE_LOCALSTORAGE=true

# Max file size in MB
REACT_APP_MAX_FILE_SIZE_MB=100

# Max rows for Excel processing
REACT_APP_MAX_ROWS=1000000
